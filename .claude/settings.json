{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "claude-plan-bridge writeback --event create --cwd '/Users/chotchki/workspace/plan_to_task_bridge'",
            "type": "command"
          }
        ],
        "matcher": "TaskCreate"
      },
      {
        "hooks": [
          {
            "command": "claude-plan-bridge writeback --event update --cwd '/Users/chotchki/workspace/plan_to_task_bridge'",
            "type": "command"
          }
        ],
        "matcher": "TaskUpdate"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "claude-plan-bridge resume --cwd '/Users/chotchki/workspace/plan_to_task_bridge'",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "claude-plan-bridge reconcile --cwd '/Users/chotchki/workspace/plan_to_task_bridge'",
            "type": "command"
          }
        ]
      }
    ]
  }
}
