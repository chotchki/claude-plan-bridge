{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "claude-plan-bridge writeback --event create",
            "type": "command"
          }
        ],
        "matcher": "TaskCreate"
      },
      {
        "hooks": [
          {
            "command": "claude-plan-bridge writeback --event update",
            "type": "command"
          }
        ],
        "matcher": "TaskUpdate"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "claude-plan-bridge reconcile",
            "type": "command"
          }
        ]
      }
    ]
  }
}
